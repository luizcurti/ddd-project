    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
